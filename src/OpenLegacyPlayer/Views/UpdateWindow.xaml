<Window x:Class="OpenLegacyPlayer.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" SizeToContent="Height" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="12">
    <Border Background="{StaticResource WindowChromeBrush}" CornerRadius="6"
            BorderBrush="{StaticResource ChromeBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#66000000" BlurRadius="14" ShadowDepth="3" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <!-- Title bar -->
            <Border Background="{StaticResource TitleBarBrush}" CornerRadius="6,6,0,0"
                    BorderBrush="{StaticResource AccentLineBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="Update available" Margin="14,8" FontSize="13"
                               Foreground="{StaticResource HeaderTextBrush}" />
                    <Button Content="&#xE8BB;" FontFamily="{StaticResource SymbolFont}" FontSize="9"
                            HorizontalAlignment="Right" Width="34" Background="Transparent"
                            BorderThickness="0" Foreground="#FF32506E" Cursor="Hand"
                            Click="Later_Click" />
                </Grid>
            </Border>

            <StackPanel Margin="18,16,18,16">
                <!-- Header: icon + version -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Width="34" Height="34" CornerRadius="5" Margin="0,0,12,0"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FFFFB43A" Offset="0" />
                                <GradientStop Color="#FFF07800" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#x25B6;" FontSize="15" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="HeadlineText" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderTextBrush}" />
                        <TextBlock x:Name="SubHeadText" FontSize="11.5" Margin="0,2,0,0"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="What's new" FontSize="12.5" FontWeight="SemiBold"
                           Foreground="{StaticResource HeaderTextBrush}" Margin="0,0,0,6" />

                <!-- Changelog -->
                <Border CornerRadius="4" Background="White" BorderThickness="1"
                        BorderBrush="{StaticResource GlassButtonBorderBrush}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="240" Padding="12,10">
                        <StackPanel x:Name="NotesPanel" />
                    </ScrollViewer>
                </Border>

                <TextBlock x:Name="HintText" FontSize="11" Margin="2,8,0,0" TextWrapping="Wrap"
                           Foreground="{StaticResource SubtleTextBrush}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="UpdateButton" Content="Update now" Click="Update_Click"
                            IsDefault="True" Padding="20,6" Margin="0,0,8,0"
                            Background="{StaticResource GlassButtonBrush}"
                            BorderBrush="{StaticResource GlassButtonBorderBrush}"
                            Foreground="{StaticResource HeaderTextBrush}" FontWeight="SemiBold"
                            Cursor="Hand" />
                    <Button Content="Ask later" Click="Later_Click" IsCancel="True"
                            Padding="18,6"
                            Background="{StaticResource GlassButtonBrush}"
                            BorderBrush="{StaticResource GlassButtonBorderBrush}"
                            Foreground="{StaticResource BodyTextBrush}" Cursor="Hand" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
