<Window x:Class="OpenLegacyPlayer.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="12">
    <Border Background="{StaticResource WindowChromeBrush}" CornerRadius="6"
            BorderBrush="{StaticResource ChromeBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#66000000" BlurRadius="14" ShadowDepth="3" Opacity="0.5" />
        </Border.Effect>
        <StackPanel Margin="0">
            <!-- Title bar -->
            <Border Background="{StaticResource TitleBarBrush}" CornerRadius="6,6,0,0"
                    BorderBrush="{StaticResource AccentLineBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="TitleText" Text="Create playlist" Margin="14,8"
                           FontSize="13" Foreground="{StaticResource HeaderTextBrush}" />
            </Border>

            <StackPanel Margin="16,14">
                <TextBlock x:Name="PromptText" Text="Name your playlist:" Margin="0,0,0,8"
                           Foreground="{StaticResource BodyTextBrush}" />
                <Border CornerRadius="4" Background="White" BorderThickness="1"
                        BorderBrush="{StaticResource GlassButtonBorderBrush}">
                    <TextBox x:Name="InputBox" BorderThickness="0" Background="Transparent"
                             Padding="7,5" FontSize="13" KeyDown="InputBox_KeyDown" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Create" Click="Ok_Click" IsDefault="True"
                            Padding="18,5" Margin="0,0,8,0"
                            Background="{StaticResource GlassButtonBrush}"
                            BorderBrush="{StaticResource GlassButtonBorderBrush}"
                            Foreground="{StaticResource HeaderTextBrush}" Cursor="Hand" />
                    <Button Content="Cancel" Click="Cancel_Click" IsCancel="True"
                            Padding="18,5"
                            Background="{StaticResource GlassButtonBrush}"
                            BorderBrush="{StaticResource GlassButtonBorderBrush}"
                            Foreground="{StaticResource BodyTextBrush}" Cursor="Hand" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
