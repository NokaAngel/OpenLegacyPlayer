<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!--  Frutiger Aero / Windows Media Player 12 colour palette        -->
    <!-- ============================================================= -->

    <Color x:Key="AeroBlueColor">#FF1C6EA4</Color>
    <SolidColorBrush x:Key="AeroBlueBrush" Color="#FF1C6EA4" />
    <Color x:Key="AeroGlowColor">#FF4DA6E8</Color>
    <Color x:Key="AeroDeepBlueColor">#FF0A3A66</Color>

    <SolidColorBrush x:Key="LinkTextBrush" Color="#FF1F5FA8" />
    <SolidColorBrush x:Key="HeaderTextBrush" Color="#FF1B4F82" />
    <SolidColorBrush x:Key="BodyTextBrush" Color="#FF1A1A1A" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF6A7480" />
    <SolidColorBrush x:Key="ColumnHeaderTextBrush" Color="#FF5A6673" />

    <!-- Outer window chrome: brushed silver-blue glass -->
    <LinearGradientBrush x:Key="WindowChromeBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFDFEFF" Offset="0.0" />
        <GradientStop Color="#FFEDF3FA" Offset="0.45" />
        <GradientStop Color="#FFDCE7F3" Offset="0.55" />
        <GradientStop Color="#FFE7F0F8" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Title bar strip -->
    <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFFFF" Offset="0.0" />
        <GradientStop Color="#FFF0F6FC" Offset="0.5" />
        <GradientStop Color="#FFE1EBF6" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Toolbar band under the tabs -->
    <LinearGradientBrush x:Key="ToolbarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF7FAFD" Offset="0.0" />
        <GradientStop Color="#FFE9F1F9" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Left navigation pane -->
    <LinearGradientBrush x:Key="NavPaneBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFF3F7FB" Offset="0.0" />
        <GradientStop Color="#FFE8EFF7" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Main content: soft watery blue-white glass gradient -->
    <LinearGradientBrush x:Key="ContentBackgroundBrush" StartPoint="0,0" EndPoint="0.3,1">
        <GradientStop Color="#FFEAF3FB" Offset="0" />
        <GradientStop Color="#FFF6FAFD" Offset="0.4" />
        <GradientStop Color="#FFFDFEFF" Offset="0.7" />
        <GradientStop Color="#FFEFF6FC" Offset="1" />
    </LinearGradientBrush>

    <!-- The signature Aero diagonal light streak sweeping bottom-left to top-right -->
    <LinearGradientBrush x:Key="ContentSheenBrush" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="#00FFFFFF" Offset="0.0" />
        <GradientStop Color="#00FFFFFF" Offset="0.48" />
        <GradientStop Color="#4CFFFFFF" Offset="0.63" />
        <GradientStop Color="#B2FFFFFF" Offset="0.72" />
        <GradientStop Color="#3CE9F4FD" Offset="0.8" />
        <GradientStop Color="#00FFFFFF" Offset="0.95" />
    </LinearGradientBrush>

    <!-- Soft blue glow that pools in the lower-right of the content, like a reflection -->
    <RadialGradientBrush x:Key="ContentGlowBrush" GradientOrigin="0.85,0.9" Center="0.85,0.9"
                         RadiusX="0.6" RadiusY="0.7">
        <GradientStop Color="#3AAFDCF6" Offset="0" />
        <GradientStop Color="#00BFE2F7" Offset="1" />
    </RadialGradientBrush>

    <!-- A single translucent glass sphere with an off-centre highlight (Frutiger Aero bubble) -->
    <RadialGradientBrush x:Key="AeroBubbleBrush" GradientOrigin="0.34,0.3" Center="0.5,0.5"
                         RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#B2FFFFFF" Offset="0" />
        <GradientStop Color="#4ADFF2FC" Offset="0.42" />
        <GradientStop Color="#2699D4F2" Offset="0.78" />
        <GradientStop Color="#4471B8E6" Offset="0.94" />
        <GradientStop Color="#0071B8E6" Offset="1" />
    </RadialGradientBrush>

    <!-- Faint rim highlight sitting just inside a bubble's edge -->
    <SolidColorBrush x:Key="AeroBubbleRimBrush" Color="#59FFFFFF" />

    <!-- Transport bar background -->
    <LinearGradientBrush x:Key="TransportBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF9FBFD" Offset="0.0" />
        <GradientStop Color="#FFEAF1F9" Offset="0.5" />
        <GradientStop Color="#FFDDE8F3" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Play/Burn tab (selected) -->
    <LinearGradientBrush x:Key="TabBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFFFF" Offset="0.0" />
        <GradientStop Color="#FFF4F8FC" Offset="0.5" />
        <GradientStop Color="#FFE7F0F8" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Glossy circular Play button (the big blue orb) -->
    <RadialGradientBrush x:Key="PlayOrbBrush" GradientOrigin="0.5,0.25" Center="0.5,0.35" RadiusX="0.75" RadiusY="0.9">
        <GradientStop Color="#FF6FC3F3" Offset="0.0" />
        <GradientStop Color="#FF2E8FD6" Offset="0.55" />
        <GradientStop Color="#FF1567A8" Offset="1.0" />
    </RadialGradientBrush>

    <LinearGradientBrush x:Key="PlayOrbGlossBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#DDFFFFFF" Offset="0.0" />
        <GradientStop Color="#22FFFFFF" Offset="0.5" />
        <GradientStop Color="#00FFFFFF" Offset="0.55" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PlayOrbRingBrush" Color="#FF17557F" />

    <!-- Now Playing dark blue backdrop -->
    <RadialGradientBrush x:Key="NowPlayingBackdropBrush" GradientOrigin="0.5,0.42" Center="0.5,0.45" RadiusX="0.85" RadiusY="0.85">
        <GradientStop Color="#FF15476E" Offset="0.0" />
        <GradientStop Color="#FF0C2E4C" Offset="0.5" />
        <GradientStop Color="#FF04101C" Offset="1.0" />
    </RadialGradientBrush>

    <!-- Generic glass button (toolbar / transport small buttons) -->
    <LinearGradientBrush x:Key="GlassButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFFFF" Offset="0.0" />
        <GradientStop Color="#FFF0F5FA" Offset="0.5" />
        <GradientStop Color="#FFDFE9F3" Offset="0.5" />
        <GradientStop Color="#FFEAF2FA" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassButtonHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFCFEFF" Offset="0.0" />
        <GradientStop Color="#FFEAF6FF" Offset="0.5" />
        <GradientStop Color="#FFC9E6FB" Offset="0.5" />
        <GradientStop Color="#FFDDF1FE" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Glossy blue for the navigation icons -->
    <LinearGradientBrush x:Key="NavIconBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF7BC0EE" Offset="0" />
        <GradientStop Color="#FF3E92D2" Offset="0.5" />
        <GradientStop Color="#FF206CA6" Offset="1" />
    </LinearGradientBrush>

    <!-- Bold, glassy blue for the transport glyphs -->
    <LinearGradientBrush x:Key="TransportGlyphBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF3E93D4" Offset="0" />
        <GradientStop Color="#FF1E6CA8" Offset="0.5" />
        <GradientStop Color="#FF124C7C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TransportGlyphHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF57B2EA" Offset="0" />
        <GradientStop Color="#FF2E8FD6" Offset="0.5" />
        <GradientStop Color="#FF1C6EA4" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="GlassButtonBorderBrush" Color="#FFA9C6E0" />
    <SolidColorBrush x:Key="ChromeBorderBrush" Color="#FF7DA0C4" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#FFD3DEEA" />
    <SolidColorBrush x:Key="AccentLineBrush" Color="#FF2E7DBF" />

    <!-- Selection highlight in lists / nav (Aero blue glow) -->
    <LinearGradientBrush x:Key="SelectionBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFDCEFFB" Offset="0.0" />
        <GradientStop Color="#FFBFE0F6" Offset="0.5" />
        <GradientStop Color="#FFA6D2F0" Offset="0.5" />
        <GradientStop Color="#FFC4E4F8" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#FF7FB8E3" />

    <LinearGradientBrush x:Key="HoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF3FAFE" Offset="0.0" />
        <GradientStop Color="#FFE3F3FD" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Segoe MDL2 Assets glyph font -->
    <FontFamily x:Key="SymbolFont">Segoe MDL2 Assets</FontFamily>

</ResourceDictionary>
