<Window x:Class="OpenLegacyPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:OpenLegacyPlayer"
        xmlns:vm="clr-namespace:OpenLegacyPlayer.ViewModels"
        xmlns:controls="clr-namespace:OpenLegacyPlayer.Controls"
        Title="OpenLegacy Player"
        Height="720" Width="1180" MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        FontFamily="Segoe UI" FontSize="12">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="28" ResizeBorderThickness="6"
                            GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVis" />
        <local:NullToVisibilityConverter x:Key="NotNullToVis" Invert="True" />
        <local:InverseBooleanToVisibilityConverter x:Key="InvBoolVis" />
        <local:BoolGlyphConverter x:Key="BoolGlyph" />
        <local:RatingConverter x:Key="Rating" />
        <local:NavGlyphConverter x:Key="NavGlyph" />
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{StaticResource WindowChromeBrush}"
            BorderBrush="{StaticResource ChromeBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />    <!-- title bar -->
                <RowDefinition Height="42" />    <!-- nav + tabs -->
                <RowDefinition Height="30" />    <!-- toolbar -->
                <RowDefinition Height="*" />     <!-- content -->
                <RowDefinition Height="72" />    <!-- transport -->
            </Grid.RowDefinitions>

            <!-- ============================ TITLE BAR ============================ -->
            <Border Grid.Row="0" Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource AccentLineBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Border Width="16" Height="16" CornerRadius="3" Margin="0,0,7,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFB43A" Offset="0" />
                                    <GradientStop Color="#FFF07800" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#x25B6;" FontSize="8" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="OpenLegacy Player" FontSize="12"
                                   Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinButton" Style="{StaticResource CaptionButton}"
                                Content="&#xE921;" Click="Minimize_Click" ToolTip="Minimize" />
                        <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}"
                                Content="&#xE922;" Click="Maximize_Click" ToolTip="Maximize" />
                        <Button x:Name="CloseButton" Style="{StaticResource CloseButton}"
                                Content="&#xE8BB;" Click="Close_Click" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ======================= NAV ARROWS + TABS ======================= -->
            <Border Grid.Row="1" Background="{StaticResource ToolbarBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource GlyphButton}" Content="&#xE72B;"
                                Width="30" Height="30" FontSize="16" ToolTip="Back"
                                Command="{Binding BackCommand}" />
                        <Button Style="{StaticResource GlyphButton}" Content="&#xE72A;"
                                Width="30" Height="30" FontSize="16" ToolTip="Forward"
                                Command="{Binding ForwardCommand}" />
                        <TextBlock Text="{Binding Breadcrumb}" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="13" Foreground="{StaticResource HeaderTextBrush}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <RadioButton Style="{StaticResource TabButton}" Content="Play" IsChecked="True" />
                        <RadioButton Style="{StaticResource TabButton}" Content="Burn" Margin="2,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ TOOLBAR ============================ -->
            <Border Grid.Row="2" Background="{StaticResource ToolbarBrush}"
                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,0,1"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid Margin="7,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Menu Background="Transparent" VerticalAlignment="Center">
                            <MenuItem Header="Organize" Padding="8,3" FontSize="12">
                                <MenuItem Header="Add folder to library…" Command="{Binding AddFolderCommand}" />
                                <MenuItem Header="Add files to library…" Command="{Binding AddFilesCommand}" />
                                <Separator />
                                <MenuItem Header="Refresh drives" Command="{Binding RefreshDrivesCommand}" />
                                <Separator />
                                <MenuItem Header="Settings…" Click="Settings_Click" />
                                <MenuItem Header="Check for updates…" Command="{Binding CheckUpdatesCommand}" />
                            </MenuItem>
                        </Menu>
                        <Border Width="1" Margin="3,5" Background="{StaticResource HairlineBrush}" />
                        <Button Style="{StaticResource ToolbarButton}" Content="Stream" />
                        <Border Width="1" Margin="3,5" Background="{StaticResource HairlineBrush}" />
                        <Button Style="{StaticResource ToolbarButton}" Command="{Binding CreatePlaylistCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Create playlist" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE710;" FontFamily="{StaticResource SymbolFont}" FontSize="9"
                                           Foreground="{StaticResource AccentLineBrush}"
                                           VerticalAlignment="Center" Margin="6,1,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource GlyphButton}" ToolTip="Change view" Width="42">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A9;" FontFamily="{StaticResource SymbolFont}" FontSize="15"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="&#xE70D;" FontFamily="{StaticResource SymbolFont}" FontSize="8"
                                           VerticalAlignment="Center" Margin="4,1,0,0" />
                            </StackPanel>
                        </Button>
                        <!-- Search box -->
                        <Border Width="216" Height="24" CornerRadius="4" Margin="8,0,0,0"
                                BorderBrush="{StaticResource GlassButtonBorderBrush}" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFFFF" Offset="0" />
                                    <GradientStop Color="#FFF3F8FC" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" Padding="7,0,24,0" FontSize="12"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                                <TextBlock Text="Search" Foreground="#FFA6B2BE" VerticalAlignment="Center"
                                           Margin="9,0,0,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="&#xE721;" FontFamily="{StaticResource SymbolFont}" FontSize="13"
                                           Foreground="{StaticResource AccentLineBrush}" HorizontalAlignment="Right"
                                           VerticalAlignment="Center" Margin="0,0,7,0" />
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource GlyphButton}" Content="&#xE897;" Margin="6,0,0,0"
                                Foreground="{StaticResource AccentLineBrush}" ToolTip="Help" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ MAIN AREA ============================ -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="182" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left navigation pane -->
                <Border Grid.Column="0" Background="{StaticResource NavPaneBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
                    <ListBox Style="{StaticResource NavListBox}" ItemsSource="{Binding NavigationItems}"
                             SelectedItem="{Binding SelectedNav, Mode=TwoWay}" Padding="0,6">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavigationItem}">
                                <StackPanel Orientation="Horizontal" Margin="{Binding Indentation}">
                                    <Grid Width="19" Height="17" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <!-- Proper Segoe MDL2 icon for library categories -->
                                        <TextBlock x:Name="glyph" FontFamily="{StaticResource SymbolFont}"
                                                   FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Text="{Binding Icon, Converter={StaticResource NavGlyph}}"
                                                   Foreground="{StaticResource NavIconBrush}">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="#FFB6DAF2" BlurRadius="1.4"
                                                                  ShadowDepth="0.5" Direction="270" Opacity="0.6" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <!-- Glossy drive block for drives -->
                                        <Grid x:Name="drive" Width="18" Height="14" Visibility="Collapsed">
                                            <Border CornerRadius="2" BorderBrush="#FF6E93B6" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FFFBFDFF" Offset="0" />
                                                        <GradientStop Color="#FFDCE9F5" Offset="0.5" />
                                                        <GradientStop Color="#FFB9CEE4" Offset="0.5" />
                                                        <GradientStop Color="#FFD3E3F2" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <Ellipse x:Name="driveLed" Width="3" Height="3" Fill="#FF35C24A"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                     Margin="0,0,2,3" />
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="12.5">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Icon}" Value="Drive">
                                        <Setter TargetName="glyph" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="drive" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Icon}" Value="RemovableDrive">
                                        <Setter TargetName="glyph" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="drive" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="driveLed" Property="Fill" Value="#FFF0A020" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Content pane -->
                <Grid Grid.Column="1" Background="{StaticResource ContentBackgroundBrush}">
                    <!-- Frutiger Aero glass bubbles floating behind the content -->
                    <Grid IsHitTestVisible="False" ClipToBounds="True">
                        <Ellipse Width="440" Height="440" Opacity="0.9"
                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                 Margin="-150,0,0,-200" Fill="{StaticResource AeroBubbleBrush}"
                                 Stroke="{StaticResource AeroBubbleRimBrush}" StrokeThickness="1.5" />
                        <Ellipse Width="250" Height="250" Opacity="0.75"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-90,80,0" Fill="{StaticResource AeroBubbleBrush}"
                                 Stroke="{StaticResource AeroBubbleRimBrush}" StrokeThickness="1.2" />
                        <Ellipse Width="160" Height="160" Opacity="0.7"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,70,150" Fill="{StaticResource AeroBubbleBrush}"
                                 Stroke="{StaticResource AeroBubbleRimBrush}" StrokeThickness="1" />
                        <Ellipse Width="96" Height="96" Opacity="0.65"
                                 HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                 Margin="140,0,0,70" Fill="{StaticResource AeroBubbleBrush}"
                                 Stroke="{StaticResource AeroBubbleRimBrush}" StrokeThickness="1" />
                    </Grid>
                    <Rectangle Fill="{StaticResource ContentGlowBrush}" IsHitTestVisible="False" />
                    <Rectangle Fill="{StaticResource ContentSheenBrush}" IsHitTestVisible="False" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Streaming / loading banner (non-blocking; rows appear live below) -->
                        <Border Grid.Row="0" Padding="12,7" BorderThickness="0,0,0,1"
                                BorderBrush="{StaticResource HairlineBrush}"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFEFF7FE" Offset="0" />
                                    <GradientStop Color="#FFDBEBF8" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource SymbolFont}"
                                               FontSize="14" Foreground="{StaticResource AccentLineBrush}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               RenderTransformOrigin="0.5,0.5">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="ScanSpin" />
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ScanSpin"
                                                            Storyboard.TargetProperty="Angle" From="0" To="360"
                                                            Duration="0:0:1.1" RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBlock.Triggers>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ScanProgressText}" FontSize="12.5"
                                               Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                                <ProgressBar Height="14" Value="{Binding ScanFound, Mode=OneWay}"
                                             Maximum="{Binding ScanTotal, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsScanIndeterminate}"
                                             Background="#FFF3F9FE" BorderBrush="#FF9FBBD6" BorderThickness="1">
                                    <ProgressBar.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8FD0F5" Offset="0" />
                                            <GradientStop Color="#FF3E9BDD" Offset="0.5" />
                                            <GradientStop Color="#FF1E73B4" Offset="1" />
                                        </LinearGradientBrush>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </StackPanel>
                        </Border>

                    <!-- Library list -->
                    <ListView Grid.Row="1" x:Name="LibraryList" ItemsSource="{Binding CurrentTracksView}"
                              SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              MouseDoubleClick="LibraryList_MouseDoubleClick"
                              PreviewMouseRightButtonDown="LibraryList_PreviewMouseRightButtonDown">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Play" Command="{Binding PlayTrackCommand}"
                                          CommandParameter="{Binding SelectedTrack}" />
                                <Separator />
                                <MenuItem Header="Add to playlist" ItemsSource="{Binding Playlists}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="Command"
                                                    Value="{Binding DataContext.AddToPlaylistCommand,
                                                            RelativeSource={RelativeSource AncestorType=MenuItem}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <MenuItem Header="Add to new playlist…" Command="{Binding AddToPlaylistCommand}" />
                                <Separator Visibility="{Binding IsViewingPlaylist, Converter={StaticResource BoolVis}}" />
                                <MenuItem Header="Remove from this playlist"
                                          Command="{Binding RemoveFromPlaylistCommand}"
                                          Visibility="{Binding IsViewingPlaylist, Converter={StaticResource BoolVis}}" />
                                <MenuItem Header="Delete this playlist"
                                          Command="{Binding DeletePlaylistCommand}"
                                          Visibility="{Binding IsViewingPlaylist, Converter={StaticResource BoolVis}}" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Foreground" Value="{StaticResource ColumnHeaderTextBrush}" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewColumnHeader">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,1">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                  HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="bd" Background="Transparent" BorderThickness="1"
                                                    BorderBrush="Transparent" Margin="0" SnapsToDevicePixels="True">
                                                <GridViewRowPresenter VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBrush}" />
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GlassButtonBorderBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource SelectionBrush}" />
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource SelectionBorderBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,10,0,2" Padding="8,2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{StaticResource HeaderTextBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" Width="300">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE768;" FontFamily="{StaticResource SymbolFont}"
                                                           FontSize="11" Foreground="{StaticResource AeroBlueBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Visibility="{Binding IsPlaying, Converter={StaticResource BoolVis}}" />
                                                <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center"
                                                           Foreground="{StaticResource LinkTextBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Length" Width="70"
                                                DisplayMemberBinding="{Binding DurationText}" />
                                <GridViewColumn Header="Rating" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Rating, Converter={StaticResource Rating}}"
                                                       FontFamily="{StaticResource SymbolFont}" FontSize="12"
                                                       Foreground="#FFE0A21A" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Contributing artist" Width="170"
                                                DisplayMemberBinding="{Binding Artist}" />
                                <GridViewColumn Header="Album" Width="170"
                                                DisplayMemberBinding="{Binding Album}" />
                                <GridViewColumn Header="Composer" Width="140"
                                                DisplayMemberBinding="{Binding Composer}" />
                                <GridViewColumn Header="Size" Width="80"
                                                DisplayMemberBinding="{Binding SizeText}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    </Grid>

                    <!-- Empty-library hint -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="&#x266B;" FontSize="64" HorizontalAlignment="Center"
                                   Foreground="#FFB6CEE4" />
                        <TextBlock Text="Your library is empty" FontSize="16" HorizontalAlignment="Center"
                                   Foreground="{StaticResource HeaderTextBrush}" Margin="0,10,0,4" />
                        <TextBlock Text="Use Organize &#x2192; Add folder to library to get started."
                                   Foreground="{StaticResource SubtleTextBrush}" HorizontalAlignment="Center" />
                        <Button Content="Add folder…" Command="{Binding AddFolderCommand}"
                                Style="{StaticResource ToolbarButton}" HorizontalAlignment="Center" Margin="0,14,0,0"
                                Padding="16,6" Background="{StaticResource GlassButtonBrush}"
                                BorderBrush="{StaticResource GlassButtonBorderBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ======================= NOW PLAYING OVERLAY ======================= -->
            <Border Grid.Row="1" Grid.RowSpan="3" Background="{StaticResource NowPlayingBackdropBrush}"
                    Visibility="{Binding IsNowPlaying, Converter={StaticResource BoolVis}}">
                <Grid ClipToBounds="True">
                    <!-- Soft light pooling from the top, like a sky glow -->
                    <Ellipse Width="1100" Height="620" VerticalAlignment="Top" Margin="0,-260,0,0"
                             IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                <GradientStop Color="#3355A9E0" Offset="0" />
                                <GradientStop Color="#0055A9E0" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Frutiger Aero glass bubbles -->
                    <Grid IsHitTestVisible="False">
                        <Ellipse Width="360" Height="360" Opacity="0.5" HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom" Margin="-120,0,0,-120"
                                 Fill="{StaticResource AeroBubbleBrush}" />
                        <Ellipse Width="200" Height="200" Opacity="0.45" HorizontalAlignment="Right"
                                 VerticalAlignment="Top" Margin="0,60,120,0"
                                 Fill="{StaticResource AeroBubbleBrush}" />
                        <Ellipse Width="120" Height="120" Opacity="0.4" HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom" Margin="0,0,180,120"
                                 Fill="{StaticResource AeroBubbleBrush}" />
                    </Grid>

                    <!-- WMP-style bars visualizer along the bottom -->
                    <controls:BarsVisualizer Height="130" VerticalAlignment="Bottom"
                                             Margin="56,0,56,8" Opacity="0.85"
                                             IsActive="{Binding IsVisualizerActive}" />

                    <!-- Top bar: app title + return to library -->
                    <TextBlock Text="Now Playing" Foreground="#CCE8F6FF" FontSize="13"
                               Margin="16,12,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                    <Button Style="{StaticResource GlyphButton}" Content="&#xE73F;" Foreground="White"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,10,0"
                            Command="{Binding ToggleNowPlayingCommand}" ToolTip="Switch to library" />

                    <!-- Centrepiece: art + reflection + track info -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,130">
                        <Grid HorizontalAlignment="Center">
                            <!-- Glow halo behind the art -->
                            <Ellipse Width="300" Height="300" IsHitTestVisible="False">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#4470C6EE" Offset="0" />
                                        <GradientStop Color="#0070C6EE" Offset="0.7" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Border x:Name="ArtHost" Width="220" Height="220" CornerRadius="10"
                                    BorderBrush="#4CFFFFFF" BorderThickness="1" SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF001322" BlurRadius="30" ShadowDepth="8"
                                                      Direction="270" Opacity="0.7" />
                                </Border.Effect>
                                <Grid>
                                    <Image Source="{Binding NowPlayingArt}" Stretch="UniformToFill"
                                           Visibility="{Binding NowPlayingArt, Converter={StaticResource NotNullToVis}}" />
                                    <Border Visibility="{Binding NowPlayingArt, Converter={StaticResource NullToVis}}"
                                            CornerRadius="9">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FF357EB0" Offset="0" />
                                                <GradientStop Color="#FF163F62" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#x266B;" FontSize="110" Foreground="#FFCDEAFB"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <!-- glossy sheen across the top of the art -->
                                    <Border CornerRadius="9,9,40,40" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#44FFFFFF" Offset="0" />
                                                <GradientStop Color="#10FFFFFF" Offset="0.4" />
                                                <GradientStop Color="#00FFFFFF" Offset="0.5" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Mirror reflection of the art -->
                        <Border Width="220" Height="70" Margin="0,2,0,0" IsHitTestVisible="False">
                            <Border.Background>
                                <VisualBrush Visual="{Binding ElementName=ArtHost}" Stretch="Fill">
                                    <VisualBrush.RelativeTransform>
                                        <ScaleTransform ScaleY="-1" CenterY="0.5" />
                                    </VisualBrush.RelativeTransform>
                                </VisualBrush>
                            </Border.Background>
                            <Border.OpacityMask>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#59000000" Offset="0" />
                                    <GradientStop Color="#00000000" Offset="0.85" />
                                </LinearGradientBrush>
                            </Border.OpacityMask>
                        </Border>

                        <TextBlock Text="{Binding NowPlayingTitle}" Foreground="White" FontSize="24"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="520" TextAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF00121F" BlurRadius="8" ShadowDepth="1" Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="{Binding NowPlayingArtist}" Foreground="#DCE9F7FF" FontSize="15"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="520" TextAlignment="Center" />
                        <TextBlock Text="{Binding NowPlayingAlbum}" Foreground="#99C6E4FA" FontSize="12.5"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="520" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ TRANSPORT BAR ============================ -->
            <Border Grid.Row="4" Background="{StaticResource TransportBarBrush}"
                    BorderBrush="{StaticResource AccentLineBrush}" BorderThickness="0,1,0,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Glass sheen overlay -->
                    <Rectangle Grid.Row="0" Grid.RowSpan="2" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#66FFFFFF" Offset="0" />
                                <GradientStop Color="#22FFFFFF" Offset="0.45" />
                                <GradientStop Color="#00FFFFFF" Offset="0.5" />
                                <GradientStop Color="#14FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Seek bar spanning the top edge -->
                    <Slider Grid.Row="0" Style="{StaticResource SeekSlider}" Margin="0,-9,0,0"
                            Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds}"
                            VerticalAlignment="Top" />

                    <Grid Grid.Row="1" Margin="10,1,12,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Now-playing mini info -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="3" Margin="0,0,8,0"
                                    BorderBrush="{StaticResource GlassButtonBorderBrush}" BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleNowPlayingCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Image Source="{Binding NowPlayingArt}" Stretch="UniformToFill" />
                                    <TextBlock Text="&#x266B;" FontSize="18" Foreground="{StaticResource AeroBlueBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding NowPlayingArt, Converter={StaticResource NullToVis}}" />
                                </Grid>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding NowPlayingTitle}" FontSize="12"
                                           Foreground="{StaticResource HeaderTextBrush}" TextTrimming="CharacterEllipsis"
                                           MaxWidth="220" />
                                <TextBlock Text="{Binding PositionText}" FontSize="11"
                                           Foreground="{StaticResource SubtleTextBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Transport controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton Style="{StaticResource TransportToggle}" Content="&#xE8B1;"
                                          IsChecked="{Binding IsShuffle, Mode=TwoWay}" ToolTip="Shuffle" />
                            <ToggleButton Style="{StaticResource TransportToggle}" Content="&#xE8EE;"
                                          IsChecked="{Binding IsRepeat, Mode=TwoWay}" ToolTip="Repeat" Margin="2,0" />
                            <Button Style="{StaticResource TransportButton}" Command="{Binding StopCommand}"
                                    ToolTip="Stop" Margin="6,0,2,0">
                                <Rectangle Width="11" Height="11" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{StaticResource TransportGlyphBrush}" />
                            </Button>
                            <Button Style="{StaticResource TransportButton}" Content="&#xE892;"
                                    Command="{Binding PreviousCommand}" ToolTip="Previous" FontSize="21" Width="36" />
                            <Button Style="{StaticResource PlayOrbButton}" Margin="4,0"
                                    Command="{Binding PlayPauseCommand}"
                                    Content="{Binding IsPlaying, Converter={StaticResource BoolGlyph}, ConverterParameter=&#xE769;|&#xE768;}" />
                            <Button Style="{StaticResource TransportButton}" Content="&#xE893;"
                                    Command="{Binding NextCommand}" ToolTip="Next" FontSize="21" Width="36" />
                            <Button Style="{StaticResource TransportButton}" Command="{Binding ToggleMuteCommand}"
                                    Content="{Binding VolumeGlyph}" ToolTip="Mute" Margin="6,0,0,0" />
                            <Slider Style="{StaticResource VolumeSlider}" Margin="4,0,0,0"
                                    Value="{Binding Volume, Mode=TwoWay}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Right: status + duration + switch to now playing -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <!-- Status message, WMP-style (e.g. "Update complete") -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="&#xE946;" FontFamily="{StaticResource SymbolFont}" FontSize="12"
                                           Foreground="{StaticResource AccentLineBrush}" VerticalAlignment="Center"
                                           Margin="0,0,5,0" />
                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11.5"
                                           Foreground="{StaticResource HeaderTextBrush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DurationText}" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource SubtleTextBrush}" FontSize="11" />
                            <Button Style="{StaticResource GlyphButton}" Content="&#xE740;"
                                    Command="{Binding ToggleNowPlayingCommand}" ToolTip="Switch to Now Playing" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
